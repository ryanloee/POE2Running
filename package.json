{
  "name": "poe2-bd-app",
  "version": "1.0.0",
  "description": "POE2 国服 BD 智能配装助手",
  "main": "electron/main.js",
  "author": "",
  "license": "MIT",
  "type": "commonjs",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:vite\" \"npm:dev:electron\"",
    "dev:vite": "vite",
    "dev:electron": "wait-on tcp:5173 && cross-env NODE_ENV=development electron .",
    "build": "vite build",
    "preview": "vite preview",
    "start": "cross-env NODE_ENV=production electron ."
  },
  "dependencies": {
    "@xenova/transformers": "^2.17.2",
    "global-agent": "^4.1.3",
    "http-proxy-agent": "^9.1.0",
    "https-proxy-agent": "^9.1.0",
    "jszip": "^3.10.1",
    "luaparse": "^0.3.1",
    "mammoth": "^1.8.0",
    "node-fetch": "^2.7.0",
    "undici": "^8.5.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.0",
    "concurrently": "^9.0.0",
    "cross-env": "^7.0.3",
    "electron": "^31.0.0",
    "vite": "^5.0.0",
    "vue": "^3.4.0",
    "wait-on": "^7.2.0"
  }
}
